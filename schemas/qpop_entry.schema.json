{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yixingz3/qpop/schemas/qpop_entry.schema.json",
  "title": "Forward-QPOP ledger entry",
  "description": "One line of a Forward-QPOP ledger (.jsonl). Every persisted entry carries the hash-chain fields (content_hash, prev_hash, entry_hash) and is one of three types: admission (pre-registration), belief_update, or outcome (terminal close). Domain-specific payload (symbol, node, decomposed_confidence, objective_gates, ...) is permitted and is hashed like every other frozen field.",
  "type": "object",
  "required": ["id", "type", "content_hash", "prev_hash", "entry_hash"],
  "properties": {
    "id": {"type": "string", "minLength": 1, "description": "Hypothesis id; stable across admission/update/outcome."},
    "type": {"enum": ["admission", "belief_update", "outcome"]},
    "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$", "description": "sha256 over the frozen (non-hash) fields."},
    "prev_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$", "description": "entry_hash of the previous entry (64 zeros at genesis)."},
    "entry_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$", "description": "sha256(content_hash || prev_hash)."}
  },
  "oneOf": [
    {
      "title": "admission",
      "required": ["type", "status", "created", "claim", "evidence", "exit_triggers"],
      "properties": {
        "type": {"const": "admission"},
        "status": {"const": "open"},
        "created": {"type": "string", "format": "date"},
        "claim": {"type": "string", "minLength": 1},
        "mechanism": {"type": "string"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "exit_triggers": {"type": "array", "items": {"$ref": "#/$defs/exit_trigger"}},
        "prior_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "role_admitted": {"type": "string"},
        "decomposed_confidence": {"$ref": "#/$defs/decomposed_confidence"}
      }
    },
    {
      "title": "belief_update",
      "required": ["type", "recorded", "evidence"],
      "properties": {
        "type": {"const": "belief_update"},
        "recorded": {"type": "string", "format": "date"},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}}
      }
    },
    {
      "title": "outcome",
      "required": ["type", "outcome", "recorded"],
      "properties": {
        "type": {"const": "outcome"},
        "status": {"enum": ["supported", "weakened", "falsified"]},
        "outcome": {"enum": ["supported", "weakened", "falsified"]},
        "recorded": {"type": "string", "format": "date"},
        "observed": {"type": "object"}
      }
    }
  ],
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["summary", "tier"],
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "tier": {"enum": ["primary", "secondary", "market_implied", "tertiary"]},
        "date": {"type": "string", "format": "date"},
        "source": {"type": "string"},
        "url": {"type": "string"}
      }
    },
    "exit_trigger": {
      "type": "object",
      "required": ["id", "metric", "op", "data_source"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "metric": {"type": "string", "minLength": 1},
        "op": {"type": "string", "minLength": 1},
        "threshold": {"type": ["number", "string"]},
        "data_source": {
          "type": "object",
          "required": ["tier"],
          "additionalProperties": true,
          "properties": {"tier": {"enum": ["primary", "secondary", "market_implied", "tertiary"]}}
        }
      }
    },
    "decomposed_confidence": {
      "type": "object",
      "description": "The scored confidence decomposition: final_confidence is the product of the five factors.",
      "required": ["bottleneck_score", "exposure_purity", "demand_score", "valuation_adjustment", "crowding_adjustment", "final_confidence"],
      "additionalProperties": false,
      "properties": {
        "bottleneck_score": {"type": "number", "minimum": 0, "maximum": 1},
        "exposure_purity": {"type": "number", "minimum": 0, "maximum": 1},
        "demand_score": {"type": "number", "minimum": 0, "maximum": 1},
        "valuation_adjustment": {"type": "number", "minimum": 0, "maximum": 1},
        "crowding_adjustment": {"type": "number", "minimum": 0, "maximum": 1},
        "final_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
