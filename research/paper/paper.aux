\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Forced selling, not recognition} (portability probe, fourth substrate). Valuation gap to information-services peers at the dislocation date~($T_0$), for historical, closed dislocations in proprietary-data businesses; point-in-time, public-data grade. Forced-seller dislocations (solid) --- a spin-off orphaned by index funds, a post-breach forced sale, a private-equity carve-out --- left real $\sim $30--40\% discounts that subsequently re-rated; \emph  {recognition} dislocations (hatched), where the market belatedly discovered a hidden data business, traded at \emph  {premiums} at~$T_0$, leaving no gap. The dashed line is the pre-registered $-20\%$ entry gate. Retrospective case studies illustrating the entry mechanism --- not assessments of the businesses or forward price views.}}{22}{figure.3}\protected@file@percent }
\newlabel{fig:forced-seller}{{3}{22}{\textbf {Forced selling, not recognition} (portability probe, fourth substrate). Valuation gap to information-services peers at the dislocation date~($T_0$), for historical, closed dislocations in proprietary-data businesses; point-in-time, public-data grade. Forced-seller dislocations (solid) --- a spin-off orphaned by index funds, a post-breach forced sale, a private-equity carve-out --- left real $\sim $30--40\% discounts that subsequently re-rated; \emph {recognition} dislocations (hatched), where the market belatedly discovered a hidden data business, traded at \emph {premiums} at~$T_0$, leaving no gap. The dashed line is the pre-registered $-20\%$ entry gate. Retrospective case studies illustrating the entry mechanism --- not assessments of the businesses or forward price views}{figure.3}{}}
\@writefile{toc}{\contentsline {paragraph}{Forced-cheap entry, and a cross-substrate negative result.}{22}{section*.27}\protected@file@percent }
