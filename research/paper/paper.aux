\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The confidence decomposition. Three evidence-scored factors and two multiplicative penalties capped at $1$ (a crowded or richly-valued name can only lose confidence, never gain it) combine into a single score, from which the position tier --- and thus sizing (core $\geq 0.22$, satellite $\geq 0.10$) --- is \emph  {derived}, not asserted.}}{7}{figure.1}\protected@file@percent }
\newlabel{fig:confidence}{{1}{7}{The confidence decomposition. Three evidence-scored factors and two multiplicative penalties capped at $1$ (a crowded or richly-valued name can only lose confidence, never gain it) combine into a single score, from which the position tier --- and thus sizing (core $\geq 0.22$, satellite $\geq 0.10$) --- is \emph {derived}, not asserted}{figure.1}{}}
